{
  "easycom": {
    "autoscan": true,
    "custom": {
      "^uv-(.*)": "@climblee/uv-ui/components/uv-$1/uv-$1.vue",
      "^(?!z-paging-refresh|z-paging-load-more)z-paging(.*)": "z-paging/components/z-paging$1/z-paging$1.vue",
      "^uni-(.*)": "@dcloudio/uni-ui/lib/uni-$1/uni-$1.vue"
    }
  },
  "pages": [
    {
      "path": "pages/home/home",
      "style": {
        "navigationBarTitleText": "首页",
        "enablePullDownRefresh": false
      }
    },
    {
      "path": "pages/price/price",
      "style": {
        "navigationBarTitleText": "蛋价",
        "enablePullDownRefresh": false
      }
    },
    {
      "path": "pages/my/my",
      "style": {
        "navigationBarTitleText": "个人中心"
      }
    },
    {
      "path": "pages/home/post-detail",
      "style": {
        "navigationBarTitleText": "文章详情",
        "enablePullDownRefresh": false
      }
    },
    {
      "path": "pages/price/trend",
      "style": {
        "navigationBarTitleText": "蛋价走势",
        "enablePullDownRefresh": false
      }
    },
    {
      "path": "pages/home/cooperation",
      "style": {
        "navigationBarTitleText": "商业合作",
        "enablePullDownRefresh": false
      }
    },
    {
      "path": "pages/my/link",
      "style": {
        "navigationBarTitleText": "关联微信",
        "enablePullDownRefresh": false
      }
    }
  ],
  "globalStyle": {
    "navigationBarTextStyle": "black",
    "navigationBarTitleText": "乘乘集团",
    "navigationBarBackgroundColor": "#FFFFFF",
    "backgroundColor": "#F8F8F8"
  },
  "tabBar": {
    "color": "#999999",
    "selectedColor": "#3c9cff",
    "backgroundColor": "#FFFFFF",
    "borderStyle": "black",
    "iconWidth": "1px",
    "list": [
      {
        "pagePath": "pages/home/home",
        "iconPath": "static/home.png",
        "selectedIconPath": "static/home-selected.png",
        "text": "首页"
      },
      {
        "pagePath": "pages/price/price",
        "iconPath": "static/egg.png",
        "selectedIconPath": "static/egg-selected.png",
        "text": "蛋价"
      },
      {
        "pagePath": "pages/my/my",
        "iconPath": "static/user.png",
        "selectedIconPath": "static/user-selected.png",
        "text": "我的"
      }
    ]
  }
}
